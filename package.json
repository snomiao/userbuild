{
  "name": "userbuild",
  "version": "0.0.0",
  "description": "A cli tool to build *.user.ts into bundled *.user.js in a human readable style",
  "keywords": [
    "bun",
    "cli",
    "userscript"
  ],
  "homepage": "https://#readme",
  "license": "MIT",
  "author": "snomiao <snomiao@gmail.com>",
  "files": [
    "*.ts",
    "dist"
  ],
  "main": "index.js",
  "bin": "./cli.ts",
  "repository": "https://github.com/snomiao/userbuild",
  "scripts": {
    "build": "bun build index.ts --outdir=dist --target=bun",
    "prepare": "husky",
    "prerelease": "bun run build && bun run test",
    "release": "bunx standard-version && git push --follow-tags && npm publish",
    "test": "bun test"
  },
  "dependencies": {
    "@types/yargs": "^17.0.35",
    "glob": "^13.0.6",
    "phpdie": "^1.7.0",
    "sflow": "^1.27.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/jest": "^30.0.0",
    "@types/md5": "^2.3.6",
    "husky": "^9.1.7",
    "md5": "^2.3.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5.8.2"
  },
  "type": "module",
  "exports": {
    "import": "./dist/index.js",
    "types": "./index.ts"
  },
  "module": "index.ts",
  "types": "./index.ts"
}
